  "publicApiSurface": [
    "POST /intern/signup - Register employee",
    "POST /intern/signin - Login employee",
    "POST /intern/logout - Logout employee",
    "POST /intern/token - Refresh access token",
    "GET /intern/all - List employees",
    "PUT /intern/update - Update employee",
    "DELETE /intern/delete - Delete employee",
    "POST /reserve/register - Create reservation",
    "GET /reserve/all - List reservations",
    "GET /reserve/get/:id - Get reservation",
    "PUT /reserve/update - Update reservation",
    "DELETE /reserve/delete - Delete reservation",
    "POST /space/register - Create space",
    "GET /space/all - List spaces",
    "GET /space/get/:id - Get space",
    "PUT /space/update - Update space",
    "DELETE /space/delete - Delete space",
    "POST /rate/register - Create rate",
    "GET /rate/all - List rates",
    "GET /rate/get/:id - Get rate",
    "PUT /rate/update - Update rate",
    "DELETE /rate/delete - Delete rate",
    "POST /partner/register - Create partner",
    "GET /partner/all - List partners",
    "GET /partner/get/:id - Get partner",
    "PUT /partner/update - Update partner",
    "DELETE /partner/delete - Delete partner",
    "POST /extra/register - Create extra",
    "GET /extra/all - List extras",
    "GET /extra/get/:id - Get extra",
    "PUT /extra/update - Update extra",
    "DELETE /extra/delete - Delete extra",
    "POST /request/register - Create request",
    "GET /request/all - List requests",
    "GET /request/get/:id - Get request",
    "PUT /request/update - Update request",
    "DELETE /request/delete - Delete request",
    "GET /report/download - Generate Excel report",
    "GET /log/reserve/all - List reservation logs"
